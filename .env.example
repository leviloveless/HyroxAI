# Copy to .env.local and fill in. Validated at boot by lib/env.ts.

# Supabase project — public, safe to expose in the browser bundle.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Anthropic API key — SERVER ONLY. Never prefix with NEXT_PUBLIC_.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: absolute site URL so signup confirmation + Stripe redirects are absolute.
# NEXT_PUBLIC_SITE_URL=https://your-app.example.com

# Optional: pin/override the generation model (defaults to claude-haiku-4-5).
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Optional: comma-separated emails exempt from the daily generation cap.
# GENERATION_UNLIMITED_EMAILS=you@example.com

# ---------------------------------------------------------------------------
# Billing (Stripe). Leave unset to run without billing. See the Stripe plan doc.
# ---------------------------------------------------------------------------
# STRIPE_SECRET_KEY=sk_test_...                     # SERVER ONLY
# STRIPE_WEBHOOK_SECRET=whsec_...                   # from `stripe listen` / dashboard
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...    # public
# STRIPE_PRICE_MONTHLY=price_...                    # $19/mo recurring price id
# STRIPE_PRICE_ANNUAL=price_...                     # $149/yr recurring price id
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # SERVER ONLY — webhook writes
# BILLING_ENABLED=false                             # set true to enforce paywall

# ---------------------------------------------------------------------------
# Wearables. Leave unset to hide/disable each integration in the Connections UI.
# ---------------------------------------------------------------------------
# STRAVA_CLIENT_ID=...                              # SERVER ONLY
# STRAVA_CLIENT_SECRET=...                          # SERVER ONLY
# OURA_CLIENT_ID=...                                # SERVER ONLY — developer.ouraring.com app
# OURA_CLIENT_SECRET=...                            # SERVER ONLY
#   Oura OAuth redirect URI to register: {NEXT_PUBLIC_SITE_URL}/api/wearables/oura/callback
# GARMIN_CLIENT_ID=...                              # SERVER ONLY (parked — program paused)
# GARMIN_CLIENT_SECRET=...                          # SERVER ONLY

# ---------------------------------------------------------------------------
# Web Push notifications (Settings → Connections "Workout reminders").
# Generate the key pair once:  npx web-push generate-vapid-keys
# Then: npm i web-push   (server dependency). Leave unset to hide the toggle.
# ---------------------------------------------------------------------------
# VAPID_PUBLIC_KEY=...                              # SERVER — from generate-vapid-keys
# VAPID_PRIVATE_KEY=...                             # SERVER ONLY — keep secret
# VAPID_SUBJECT=mailto:support@duravel.app          # contact URL/mailto for push services
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=...                  # SAME as VAPID_PUBLIC_KEY (exposed to browser)

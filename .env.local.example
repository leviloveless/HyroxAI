# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Used to build the email-confirmation redirect link. Set to your
# deployed URL in production (e.g. https://hyroxai.vercel.app);
# http://localhost:3000 is fine for local dev.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Anthropic — server-side only, never exposed to the browser
ANTHROPIC_API_KEY=

# Web Push (optional) — `npx web-push generate-vapid-keys`, then `npm i web-push`.
# Leave unset to hide the "Workout reminders" toggle in Settings → Connections.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@duravel.app
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
